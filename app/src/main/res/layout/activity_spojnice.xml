<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- ===== REZULTAT MEČA ===== -->
    <com.example.slagalica.ui.widget.ScoreBarView
        android:id="@+id/scoreBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/tvRoundLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textStyle="bold"
        tools:text="Runda 1 / 2" />

    <TextView
        android:id="@+id/tvTurnStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginBottom="4dp"
        android:textAppearance="?attr/textAppearanceLabelLarge"
        android:textStyle="bold"
        tools:text="Ti si na potezu!" />

    <!-- ===== KRITERIJUM ===== -->
    <TextView
        android:id="@+id/tvCriterion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginBottom="4dp"
        android:textAppearance="?attr/textAppearanceLabelLarge"
        android:textStyle="italic"
        tools:text="Kriterijum: Povežite države sa prestonicama" />

    <!-- ===== INSTRUKCIJA ===== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        android:text="@string/spojnice_instruction"
        android:textAppearance="?attr/textAppearanceBodySmall" />

    <!-- ===== LEVA I DESNA KOLONA ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- LEVA KOLONA -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLeft0"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                tools:text="Srbija" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLeft1"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                tools:text="Francuska" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLeft2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                tools:text="Japan" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLeft3"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                tools:text="Brazil" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLeft4"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                tools:text="Australija" />

        </LinearLayout>

        <!-- DESNA KOLONA -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRight0"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                tools:text="Pariz" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRight1"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                tools:text="Beograd" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRight2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                tools:text="Brazilija" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRight3"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                tools:text="Kanbera" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRight4"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:cornerRadius="8dp"
                tools:text="Tokio" />

        </LinearLayout>

    </LinearLayout>

    <!-- ===== FOOTER: Predaj ===== -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGiveUp"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/spojnice_btn_give_up"
        android:textAllCaps="false" />

</LinearLayout>
