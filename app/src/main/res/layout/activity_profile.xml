<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="@string/profile_title" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== Kartica: avatar i osnovni podaci ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Avatar -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_gravity="center_horizontal"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        android:src="@mipmap/ic_launcher"
                        app:shapeAppearance="@style/ShapeAppearance.Avatar.Circle"
                        app:strokeColor="@color/profile_avatar_stroke"
                        app:strokeWidth="3dp"
                        tools:ignore="ContentDescription" />

                    <!-- Dugme za promenu avatara -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChangeAvatar"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/profile_btn_change_avatar"
                        android:textAllCaps="false" />

                    <!-- Korisničko ime -->
                    <TextView
                        android:id="@+id/tvUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textStyle="bold"
                        tools:text="marko123" />

                    <!-- Email -->
                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        tools:text="marko@example.com" />

                    <!-- Čipovi: liga + region -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipLeague"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:checkable="false"
                            android:clickable="false"
                            tools:text="Liga: Nulta" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipRegion"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checkable="false"
                            android:clickable="false"
                            tools:text="Region: Beograd" />

                    </LinearLayout>

                    <!-- Čipovi: tokeni + zvezde -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTokens"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:checkable="false"
                            android:clickable="false"
                            tools:text="Žetoni: 5" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipStars"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checkable="false"
                            android:clickable="false"
                            tools:text="Zvezde: 42 ⭐" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Kartica: QR kod ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/profile_qr_title"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textStyle="bold" />

                    <!-- QR kod sa UID-jem korisnika (poziv za prijatelja) -->
                    <ImageView
                        android:id="@+id/ivQrCode"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:background="@drawable/bg_qr_placeholder"
                        android:contentDescription="@string/profile_qr_title"
                        android:padding="8dp"
                        android:scaleType="fitCenter" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Kartica: statistika ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/profile_stats_title"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textStyle="bold" />

                    <!-- Ukupno partija + odnos pobeda/poraza -->
                    <TextView
                        android:id="@+id/tvTotalGames"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        tools:text="Ukupno partija: 15" />

                    <!-- Odnos pobeda/poraza -->
                    <TextView
                        android:id="@+id/tvWinRate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        tools:text="Pobede / Porazi: 60% / 40%" />

                    <ProgressBar
                        android:id="@+id/pbWinRate"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:max="100"
                        android:progress="60" />

                    <!-- Ko zna zna -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_stat_kzz_title"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStatKzz"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        tools:text="Pogođena pitanja: 73%" />

                    <TextView
                        android:id="@+id/tvStatKzzDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        tools:text="Pogođeno: 55  |  Promašeno: 20" />

                    <TextView
                        android:id="@+id/tvStatKzzAvg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        tools:text="Prosečno bodova po igri: 22.5" />

                    <ProgressBar
                        android:id="@+id/pbKzz"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="10dp"
                        android:max="100"
                        android:progress="73" />

                    <!-- Moj broj -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_stat_moj_broj_title"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStatMojBroj"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        tools:text="Tačan rezultat: 45%" />

                    <ProgressBar
                        android:id="@+id/pbMojBroj"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="10dp"
                        android:max="100"
                        android:progress="45" />

                    <!-- Korak po korak -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_stat_korak_title"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStatKorak"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="10dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        tools:text="Prosečan korak pogotka: 3.2 / 7" />

                    <!-- Asocijacije -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_stat_asoc_title"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStatAsoc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="10dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        tools:text="Rešeno: 58%  |  Nerešeno: 42%" />

                    <!-- Skočko -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_stat_skocko_title"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStatSkocko"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        tools:text="Pogodak u 1–2. pokušaju: 35%" />

                    <ProgressBar
                        android:id="@+id/pbSkocko"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="10dp"
                        android:max="100"
                        android:progress="35" />

                    <!-- Spojnice -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_stat_spojnice_title"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStatSpojnice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        tools:text="Uspešno povezano: 78%" />

                    <TextView
                        android:id="@+id/tvStatSpojniceAvg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        tools:text="Prosečno bodova po igri: 8.0" />

                    <ProgressBar
                        android:id="@+id/pbSpojnice"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="4dp"
                        android:max="100"
                        android:progress="78" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Dugme: Odjava ===== -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/profile_btn_logout"
                android:textAllCaps="false"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
