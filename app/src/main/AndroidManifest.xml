<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Required on Android 13+ (API 33) to post system tray notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Slagalica">

        <!-- Launcher: LoginActivity -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.auth.ForgotPasswordActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.games.KorakPoKorakActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.games.MojBrojActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.games.GameMenuActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.profile.ProfileActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.games.KoZnaZnaActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.games.SpojniceActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.games.SkockoActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.games.AsocijacijeActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.notifications.NotificationsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.match.MatchmakingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.match.MatchResultActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.chat.ChatActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.challenge.ChallengeListActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.challenge.ChallengeLobbyActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.challenge.ChallengeResultActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.challenge.ChallengeSoloRunnerActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.challenge.ChallengeSoloKzzActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.challenge.ChallengeSoloSpojniceActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.challenge.ChallengeSoloMojBrojActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.challenge.ChallengeSoloKorakActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!--
            FCM service — receives push tokens and data messages.
            MESSAGING_EVENT intent filter is required for firebase-messaging to work.
            exported="false" is safe: FCM binds to it directly via the filter.
        -->
        <service
            android:name=".data.repository.SlagalicaMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>